---
import '@adsites/ui-kit/styles/global.css';
import '@adsites/ui-kit/styles/tool-page.css';
import ToolLayout from '@adsites/ui-kit/ToolLayout.astro';
import { SITE, TOOLS } from '../../config';

const tool = TOOLS.find(t => t.slug === 'lorem-ipsum')!;
const faq = [
  { question: 'What is Lorem Ipsum?', answer: 'Lorem Ipsum is standard placeholder text used since the 1500s in the printing and typesetting industry. It helps designers and developers fill layouts with realistic-looking text before the final content is available.' },
  { question: 'Is the generated text real Latin?', answer: 'It is based on a section from "De Finibus Bonorum et Malorum" by Cicero (45 BC), but words have been altered and randomized over centuries, so it is not actual readable Latin.' },
  { question: 'Can I generate custom amounts?', answer: 'Yes! You can choose between paragraphs, sentences, or words, and specify exactly how many you need.' },
];
---

<ToolLayout
  title={tool.name}
  description={tool.description}
  siteName={SITE.name}
  siteUrl={SITE.url}
  tools={TOOLS}
  faq={faq}
>
  <div class="tool-header">
    <h1>{tool.icon} {tool.name}</h1>
    <p class="tool-description">{tool.description}</p>
  </div>

  <div class="tool-container">
    <div class="lorem-controls">
      <div class="control-group">
        <label for="lorem-count">Amount</label>
        <input
          type="number"
          id="lorem-count"
          class="input"
          min="1"
          max="100"
          value="3"
        />
      </div>

      <div class="control-group">
        <label>Unit</label>
        <div class="toggle-group" id="unit-group">
          <button class="toggle-btn active" data-unit="paragraphs">Paragraphs</button>
          <button class="toggle-btn" data-unit="sentences">Sentences</button>
          <button class="toggle-btn" data-unit="words">Words</button>
        </div>
      </div>

      <div class="control-group">
        <label>
          <input type="checkbox" id="start-lorem" checked />
          Start with "Lorem ipsum..."
        </label>
      </div>

      <button id="btn-generate" class="btn btn-primary">✨ Generate</button>
    </div>

    <div class="tool-result">
      <div class="tool-result-header">
        <h2>Generated Text</h2>
        <button id="btn-copy" class="btn btn-secondary">📋 Copy</button>
      </div>
      <div class="tool-result-content" id="result"></div>
    </div>
  </div>
</ToolLayout>

<style>
  .lorem-controls {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: var(--space-4);
  }

  .control-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .control-group label {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-secondary);
  }

  .control-group input[type="number"] {
    width: 100px;
  }

  .toggle-group {
    display: flex;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .toggle-btn {
    padding: var(--space-2) var(--space-4);
    background: var(--color-bg-secondary);
    border: none;
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .toggle-btn:not(:last-child) {
    border-right: 1px solid var(--color-border);
  }

  .toggle-btn.active {
    background: var(--color-accent);
    color: white;
  }

  .toggle-btn:hover:not(.active) {
    background: var(--color-bg-tertiary);
  }

  .control-group input[type="checkbox"] {
    accent-color: var(--color-accent);
    transform: scale(1.15);
    margin-right: var(--space-1);
  }

  @media (max-width: 640px) {
    .lorem-controls {
      flex-direction: column;
      align-items: stretch;
    }

    .control-group input[type="number"] {
      width: 100%;
    }
  }
</style>

<script>
  const LOREM_WORDS = [
    'lorem','ipsum','dolor','sit','amet','consectetur','adipiscing','elit','sed','do',
    'eiusmod','tempor','incididunt','ut','labore','et','dolore','magna','aliqua','enim',
    'ad','minim','veniam','quis','nostrud','exercitation','ullamco','laboris','nisi',
    'aliquip','ex','ea','commodo','consequat','duis','aute','irure','in','reprehenderit',
    'voluptate','velit','esse','cillum','fugiat','nulla','pariatur','excepteur','sint',
    'occaecat','cupidatat','non','proident','sunt','culpa','qui','officia','deserunt',
    'mollit','anim','id','est','laborum','ac','accumsan','arcu','at','ante','bibendum',
    'blandit','commodo','congue','cras','cursus','diam','dictum','dignissim','donec',
    'egestas','elementum','facilisis','faucibus','felis','fermentum','gravida','habitant',
    'hendrerit','iaculis','interdum','justo','lacinia','lectus','leo','libero','ligula',
    'lobortis','luctus','maecenas','massa','mattis','mauris','metus','morbi','nam',
    'neque','netus','nibh','nunc','odio','orci','ornare','pellentesque','pharetra',
    'placerat','porta','posuere','praesent','pretium','proin','pulvinar','purus',
    'rhoncus','risus','rutrum','sagittis','sapien','scelerisque','semper','senectus',
    'sociis','sodales','sollicitudin','suspendisse','tellus','tincidunt','tortor',
    'tristique','turpis','ultrices','urna','varius','vel','vestibulum','vitae','viverra',
    'volutpat','vulputate',
  ];

  const FIRST_SENTENCE = 'Lorem ipsum dolor sit amet, consectetur adipiscing elit.';

  function randomWord(): string {
    return LOREM_WORDS[Math.floor(Math.random() * LOREM_WORDS.length)];
  }

  function generateSentence(wordCount?: number): string {
    const count = wordCount || (5 + Math.floor(Math.random() * 12));
    const words = Array.from({ length: count }, () => randomWord());
    words[0] = words[0].charAt(0).toUpperCase() + words[0].slice(1);
    return words.join(' ') + '.';
  }

  function generateParagraph(): string {
    const sentenceCount = 4 + Math.floor(Math.random() * 5);
    return Array.from({ length: sentenceCount }, () => generateSentence()).join(' ');
  }

  function generate() {
    const countEl = document.getElementById('lorem-count') as HTMLInputElement;
    const count = Math.max(1, Math.min(100, parseInt(countEl.value) || 3));
    const unit = document.querySelector('.toggle-btn.active')?.getAttribute('data-unit') || 'paragraphs';
    const startWithLorem = (document.getElementById('start-lorem') as HTMLInputElement).checked;

    let output = '';

    switch (unit) {
      case 'paragraphs': {
        const paragraphs = Array.from({ length: count }, () => generateParagraph());
        if (startWithLorem) {
          paragraphs[0] = FIRST_SENTENCE + ' ' + paragraphs[0];
        }
        output = paragraphs.join('\n\n');
        break;
      }
      case 'sentences': {
        const sentences = Array.from({ length: count }, () => generateSentence());
        if (startWithLorem) {
          sentences[0] = FIRST_SENTENCE;
        }
        output = sentences.join(' ');
        break;
      }
      case 'words': {
        const words = Array.from({ length: count }, () => randomWord());
        if (startWithLorem && count >= 2) {
          words[0] = 'lorem';
          words[1] = 'ipsum';
        }
        output = words.join(' ');
        break;
      }
    }

    document.getElementById('result')!.textContent = output;
  }

  // Unit toggle
  document.getElementById('unit-group')?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.toggle-btn');
    if (!btn) return;
    document.querySelectorAll('.toggle-btn').forEach((b) => b.classList.remove('active'));
    btn.classList.add('active');
    generate();
  });

  // Generate button
  document.getElementById('btn-generate')?.addEventListener('click', generate);

  // Copy
  document.getElementById('btn-copy')?.addEventListener('click', async () => {
    const text = document.getElementById('result')!.textContent || '';
    await navigator.clipboard.writeText(text);
    const btn = document.getElementById('btn-copy')!;
    btn.textContent = '✅ Copied!';
    setTimeout(() => { btn.textContent = '📋 Copy'; }, 1500);
  });

  // Initial generate
  generate();
</script>
