---
import '@adsites/ui-kit/styles/global.css';
import '@adsites/ui-kit/styles/tool-page.css';
import ToolLayout from '@adsites/ui-kit/ToolLayout.astro';
import { SITE, TOOLS } from '../../config';

const tool = TOOLS.find(t => t.slug === 'case-converter')!;
const faq = [
  { question: 'What case conversions are supported?', answer: 'We support: UPPERCASE, lowercase, Title Case, Sentence case, camelCase, PascalCase, snake_case, kebab-case, CONSTANT_CASE, and dot.case.' },
  { question: 'Is this tool free?', answer: 'Yes — completely free with no limits. Use it as many times as you need.' },
  { question: 'Can I convert code variable names?', answer: 'Absolutely! Use camelCase, PascalCase, snake_case, or CONSTANT_CASE for programming variable names.' },
];
---

<ToolLayout
  title={tool.name}
  description={tool.description}
  siteName={SITE.name}
  siteUrl={SITE.url}
  tools={TOOLS}
  faq={faq}
>
  <div class="tool-header">
    <h1>{tool.icon} {tool.name}</h1>
    <p class="tool-description">{tool.description}</p>
  </div>

  <div class="tool-container">
    <textarea
      id="text-input"
      class="input"
      placeholder="Type or paste your text here..."
      rows="6"
      aria-label="Enter text to convert case"
    ></textarea>

    <div class="case-buttons" id="case-buttons">
      <button class="btn btn-secondary" data-case="upper">UPPERCASE</button>
      <button class="btn btn-secondary" data-case="lower">lowercase</button>
      <button class="btn btn-secondary" data-case="title">Title Case</button>
      <button class="btn btn-secondary" data-case="sentence">Sentence case</button>
      <button class="btn btn-secondary" data-case="camel">camelCase</button>
      <button class="btn btn-secondary" data-case="pascal">PascalCase</button>
      <button class="btn btn-secondary" data-case="snake">snake_case</button>
      <button class="btn btn-secondary" data-case="kebab">kebab-case</button>
      <button class="btn btn-secondary" data-case="constant">CONSTANT_CASE</button>
      <button class="btn btn-secondary" data-case="dot">dot.case</button>
    </div>

    <div class="tool-result">
      <div class="tool-result-header">
        <h2>Result</h2>
        <button id="btn-copy" class="btn btn-primary">📋 Copy</button>
      </div>
      <div class="tool-result-content" id="result"></div>
    </div>
  </div>
</ToolLayout>

<style>
  .case-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .case-buttons .btn.active {
    background: var(--color-accent-gradient);
    color: white;
    border-color: transparent;
  }
</style>

<script>
  const input = document.getElementById('text-input') as HTMLTextAreaElement;
  const result = document.getElementById('result')!;
  let activeCase = '';

  function toWords(text: string): string[] {
    return text
      .replace(/([a-z])([A-Z])/g, '$1 $2') // camelCase split
      .replace(/[_\-\.]/g, ' ')              // separators to spaces
      .trim()
      .split(/\s+/)
      .filter(Boolean);
  }

  function convertCase(text: string, type: string): string {
    if (!text.trim()) return '';

    switch (type) {
      case 'upper':
        return text.toUpperCase();
      case 'lower':
        return text.toLowerCase();
      case 'title':
        return text.replace(/\w\S*/g, (w) =>
          w.charAt(0).toUpperCase() + w.slice(1).toLowerCase()
        );
      case 'sentence':
        return text
          .toLowerCase()
          .replace(/(^\w|[.!?]\s+\w)/g, (c) => c.toUpperCase());
      case 'camel': {
        const words = toWords(text);
        return words
          .map((w, i) =>
            i === 0
              ? w.toLowerCase()
              : w.charAt(0).toUpperCase() + w.slice(1).toLowerCase()
          )
          .join('');
      }
      case 'pascal': {
        const words = toWords(text);
        return words
          .map((w) => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase())
          .join('');
      }
      case 'snake':
        return toWords(text).join('_').toLowerCase();
      case 'kebab':
        return toWords(text).join('-').toLowerCase();
      case 'constant':
        return toWords(text).join('_').toUpperCase();
      case 'dot':
        return toWords(text).join('.').toLowerCase();
      default:
        return text;
    }
  }

  function update() {
    if (activeCase) {
      result.textContent = convertCase(input.value, activeCase);
    }
  }

  // Case button clicks
  document.getElementById('case-buttons')?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-case]') as HTMLElement;
    if (!btn) return;

    // Update active state
    document.querySelectorAll('[data-case]').forEach((b) => b.classList.remove('active'));
    btn.classList.add('active');

    activeCase = btn.dataset.case!;
    update();
  });

  input.addEventListener('input', update);

  // Copy result
  document.getElementById('btn-copy')?.addEventListener('click', async () => {
    await navigator.clipboard.writeText(result.textContent || '');
    const btn = document.getElementById('btn-copy')!;
    btn.textContent = '✅ Copied!';
    setTimeout(() => { btn.textContent = '📋 Copy'; }, 1500);
  });
</script>
