---
import '@adsites/ui-kit/styles/global.css';
import '@adsites/ui-kit/styles/tool-page.css';
import Header from '@adsites/ui-kit/Header.astro';
import Footer from '@adsites/ui-kit/Footer.astro';
import AdSlot from '@adsites/ui-kit/AdSlot.astro';
import { SITE, TOOLS } from '../config';

const lastUpdated = 'July 23, 2026';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Terms of Service — {SITE.name}</title>
    <meta name="description" content={`Terms of Service for ${SITE.name}. Read our terms of use, service conditions, and disclaimer.`} />
    <link rel="canonical" href={`${SITE.url}/terms`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <script is:inline>
      (function() {
        const t = localStorage.getItem('theme') ||
          (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
  </head>
  <body>
    <Header siteName={SITE.name} siteUrl={SITE.url} tools={TOOLS} />

    <main class="legal-page container">
      <header class="legal-header">
        <h1>Terms of Service</h1>
        <p class="last-updated">Last Updated: {lastUpdated}</p>
      </header>

      <div class="legal-content">
        <section>
          <h2>1. Agreement to Terms</h2>
          <p>
            By accessing or using <strong>{SITE.name}</strong> (<a href={SITE.url}>{SITE.url}</a>), you agree to be bound by these Terms of Service. If you do not agree to these terms, please do not use our website or services.
          </p>
        </section>

        <section>
          <h2>2. Description of Service</h2>
          <p>
            {SITE.name} provides free, browser-based text utility tools including word counting, case conversion, text manipulation, and formatting tools. All services are provided "as is" and "as available" without warranty of any kind.
          </p>
        </section>

        <section>
          <h2>3. Permitted Use</h2>
          <p>You agree to use {SITE.name} only for lawful purposes. You may not:</p>
          <ul>
            <li>Use the site in any way that violates applicable local, national, or international law.</li>
            <li>Attempt to reverse engineer, decompile, or disrupt our web application infrastructure.</li>
            <li>Use automated bots or scrapers to overload our site infrastructure.</li>
          </ul>
        </section>

        <section>
          <h2>4. Intellectual Property</h2>
          <p>
            The software, design, branding, code, and interface of {SITE.name} are owned by us and protected by copyright and intellectual property laws. You retain full ownership of any text content you input or process through our tools.
          </p>
        </section>

        <section>
          <h2>5. Disclaimer of Warranties & Limitation of Liability</h2>
          <p>
            While we strive for 100% precision in all calculations and transformations, {SITE.name} makes no guarantees regarding the completeness, reliability, or accuracy of any output generated by our tools.
          </p>
          <p>
            In no event shall {SITE.name} be liable for any direct, indirect, incidental, or consequential damages resulting from the use or inability to use our tools.
          </p>
        </section>

        <section>
          <h2>6. Changes to Terms</h2>
          <p>
            We reserve the right to modify these Terms of Service at any time. Continued use of the website following any changes constitutes acceptance of the new terms.
          </p>
        </section>

        <section>
          <h2>7. Contact Information</h2>
          <p>
            Questions regarding these Terms of Service should be directed to <a href="mailto:support@fixmytext.com">support@fixmytext.com</a>.
          </p>
        </section>
      </div>
    </main>

    <AdSlot position="bottom" />
    <Footer siteName={SITE.name} siteUrl={SITE.url} />
  </body>
</html>

<style>
  .legal-page {
    max-width: 800px;
    margin-inline: auto;
    padding: var(--space-12) var(--space-4);
  }

  .legal-header {
    border-bottom: 2px solid var(--color-border);
    padding-bottom: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .legal-header h1 {
    font-size: var(--text-3xl);
    font-weight: var(--font-weight-bold);
  }

  .last-updated {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    margin-top: var(--space-1);
  }

  .legal-content section {
    margin-bottom: var(--space-8);
  }

  .legal-content h2 {
    font-size: var(--text-xl);
    font-weight: var(--font-weight-semibold);
    margin-bottom: var(--space-3);
    color: var(--color-text-primary);
  }

  .legal-content p, .legal-content li {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    margin-bottom: var(--space-3);
  }

  .legal-content ul {
    padding-left: var(--space-6);
    margin-bottom: var(--space-4);
  }

  .legal-content li {
    margin-bottom: var(--space-2);
  }
</style>
